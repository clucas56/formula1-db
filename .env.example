# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — never commit real secrets.

# -----------------------------------------------------------------------------
# PostgreSQL — main (read/write) role. Used by ingestion and by the API for
# everything except the /query text-to-SQL endpoint.
# -----------------------------------------------------------------------------
DB_NAME=f1_data
DB_USER=f1user
DB_PASSWORD=change-me-to-a-strong-password

# -----------------------------------------------------------------------------
# PostgreSQL — read-only role for the /query (text-to-SQL) endpoint.
# Created in HANDOFF.md Phase 6. Until you create it, you can point these at
# the same values as DB_USER / DB_PASSWORD above — but DO create the real
# read-only role before exposing /query publicly.
# -----------------------------------------------------------------------------
DB_RO_USER=f1reader
DB_RO_PASSWORD=change-me-to-a-different-strong-password

# -----------------------------------------------------------------------------
# Anthropic API (for the text-to-SQL endpoint)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# -----------------------------------------------------------------------------
# Ingestion schedule (cron syntax) — default Monday 6am
# Examples:
#   0 6 * * 1     -> Monday 6:00am
#   0 */6 * * *   -> Every 6 hours
#   30 5 * * 1,4  -> Monday and Thursday at 5:30am
# -----------------------------------------------------------------------------
INGESTION_CRON=0 6 * * 1
